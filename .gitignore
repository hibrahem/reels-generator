# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv
# (uv.lock IS committed)

# Project data — never commit source videos, transcripts, or rendered output
/input/
/output/
/work/
*.mp4
*.mov
*.mkv
*.wav
*.json.transcript

# Whisper model cache
/models/

# Locally compiled ffmpeg (with libass) — not committed
/vendor/

# Secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
.vscode/

# Allow sample assets and configs to be committed
!assets/**
!config.yaml
!config.example.yaml

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
