# Copy to .env (which is git-ignored) and fill in your key. Only the transcript TEXT is ever sent.
# Which key you need depends on selection.provider in config.yaml:

# provider: deepseek  (default)
DEEPSEEK_API_KEY=

# provider: openai
# OPENAI_API_KEY=

# provider: claude
# ANTHROPIC_API_KEY=

# Optional overrides (otherwise taken from config.yaml):
# REELS_SELECTION_MODEL=deepseek-chat
# REELS_SELECTION_BASE_URL=https://api.deepseek.com
